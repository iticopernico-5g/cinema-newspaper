{
    "url": "http://localhost/repo/cinema-newspaper/",
    "base-directory": "repo/cinema-newspaper/",
    "log-file": "app.log",
    "actions": "actions/",
    "api": "api/",
    "pages": "pages/",
    "resources": "resources/",
    "texts": {
        "enabled": true,
        "path": "resources/texts/texts.json",
        "default-language": "it"
    },
    "autoload": {
        "namespaces": {
            "App\\": "app/",
            "Camezilla\\": "camezilla/"
        }
    },
    "database": {
        "enabled": true,
        "host": "localhost",
        "user": "root",
        "password": "",
        "name": "cinema_newspaper",
        "error-page": "error.php"
    },
    "authentication": {
        "enabled": true,
        "secret-key": "your-secret-key",
        "login-page": "login.php"
    },
    "mail": {
        "enabled": false,
        "host": "host@example.com"
    }
}